  <section class="admission-section" id="admission">
        <div class="container">
          <div class="section-header animate-on-scroll">
            <div class="section-badge">
              <i class="fas fa-user-plus"></i> Inscription
            </div>
            <h2>Rejoignez la Famille GEORGES I</h2>
            <p>
              Les inscriptions sont ouvertes pour la prochaine année scolaire.
              Offrez le meilleur à votre enfant.
            </p>
          </div>
          <div class="admission-wrapper">
            <div class="admission-info animate-on-scroll">
              <h3>Processus d'Inscription</h3>
              <p>
                L'inscription au Complexe Scolaire Bilingue GEORGES I est simple
                et rapide. Suivez les étapes ci-dessous pour inscrire votre
                enfant.
              </p>
              <div class="process-steps">
                <div class="step">
                  <div class="step-number">1</div>
                  <div class="step-content">
                    <h4>Pré-inscription en ligne</h4>
                    <p>
                      Remplissez le formulaire ci-contre avec les informations de
                      votre enfant.
                    </p>
                  </div>
                </div>
                <div class="step">
                  <div class="step-number">2</div>
                  <div class="step-content">
                    <h4>Constitution du dossier</h4>
                    <p>
                      Préparez les documents requis : bulletins, acte de
                      naissance, photos d'identité.
                    </p>
                  </div>
                </div>
                <div class="step">
                  <div class="step-number">3</div>
                  <div class="step-content">
                    <h4>Test d'évaluation</h4>
                    <p>
                      Un test de niveau pourra être organisé selon le cycle
                      demandé.
                    </p>
                  </div>
                </div>
                <div class="step">
                  <div class="step-number">4</div>
                  <div class="step-content">
                    <h4>Validation & paiement</h4>
                    <p>
                      Après acceptation, finalisez l'inscription avec le règlement
                      des frais de scolarité.
                    </p>
                  </div>
                </div>
              </div>
            </div>
            <div class="admission-form animate-on-scroll">
              <h3>Pré-inscription en ligne</h3>
              <p class="form-subtitle">
                Remplissez ce formulaire et nous vous recontacterons rapidement.
              </p>
              <form id="inscriptionForm">
                <div class="form-row">
                  <div class="form-group">
                    <label>Nom de l'élève</label>
                    <input type="text" placeholder="Nom complet" required />
                  </div>
                  <div class="form-group">
                    <label>Date de naissance</label>
                    <input type="date" required />
                  </div>
                </div>
                <div class="form-group">
                  <label>Cycle souhaité</label>
                  <select required>
                    <option value="">Sélectionnez un cycle</option>
                    <option>Maternel</option>
                    <option>Primaire Francophone</option>
                    <option>Primaire Anglophone</option>
                    <option>Secondaire Francophone</option>
                    <option>Secondaire Anglophone</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Classe demandée</label>
                  <input
                    type="text"
                    placeholder="Ex: CM1, Form 3, 6ème..."
                    required
                  />
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label>Nom du parent/tuteur</label>
                    <input type="text" placeholder="Nom complet" required />
                  </div>
                  <div class="form-group">
                    <label>Téléphone</label>
                    <input type="tel" placeholder="+237 6XX XXX XXX" required />
                  </div>
                </div>
                <div class="form-group">
                  <label>Email</label>
                  <input type="email" placeholder="votre@email.com" required />
                </div>
                <div class="form-group">
                  <label>Message (optionnel)</label>
                  <textarea rows="3" placeholder="Informations complémentaires..."
                  ></textarea>
                </div>
                <button type="submit" class="form-submit">
                  <i class="fas fa-paper-plane"></i> Envoyer la pré-inscription
                </button>
              </form>
            </div>
          </div>
        </div>
      </section>